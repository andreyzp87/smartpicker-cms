{
  "name": "smartpicker-cms",
  "version": "0.1.0",
  "description": "SmartPicker CMS - Device Compatibility Database",
  "main": "dist/index.js",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "ioredis": "5.8.2"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsup && pnpm build:admin",
    "build:server": "tsup",
    "build:admin": "cd admin && pnpm build",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "cli": "tsx src/cli.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed-db.ts",
    "extract:z2m": "tsx scripts/extract-z2m-devices.ts",
    "extract:blakadder": "tsx scripts/extract-blakadder-devices.ts",
    "extract:zwave": "tsx scripts/extract-zwave-devices.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.966.0",
    "@hono/node-server": "^1.19.7",
    "@hono/trpc-server": "^0.4.1",
    "@trpc/server": "^11.8.1",
    "bullmq": "^5.66.4",
    "cheerio": "^1.1.2",
    "commander": "^14.0.2",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.11.3",
    "ioredis": "5.8.2",
    "js-yaml": "^4.1.1",
    "json5": "^2.2.3",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.8",
    "slugify": "^1.6.6",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.0.3",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.7.4",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0"
  }
}
