{
  "name": "smartpicker-cms",
  "version": "0.1.0",
  "description": "SmartPicker CMS - Device Compatibility Database",
  "main": "dist/index.js",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "ioredis": "5.8.2"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "pnpm build:server && pnpm build:admin",
    "build:server": "tsup",
    "build:admin": "pnpm --dir admin build",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "cli": "tsx src/cli.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed-db.ts",
    "extract:z2m": "tsx scripts/extract-z2m-devices.ts",
    "extract:blakadder": "tsx scripts/extract-blakadder-devices.ts",
    "extract:zwave": "tsx scripts/extract-zwave-devices.ts",
    "lint": "pnpm lint:server && pnpm lint:admin",
    "lint:server": "eslint src drizzle.config.ts tsup.config.ts",
    "lint:admin": "eslint admin/src admin/vite.config.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm test:server && pnpm test:admin",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:server": "vitest run --config vitest.config.ts",
    "test:admin": "vitest run --config admin/vitest.config.ts",
    "typecheck": "pnpm typecheck:server && pnpm typecheck:admin",
    "typecheck:server": "tsc --noEmit -p tsconfig.json",
    "typecheck:admin": "pnpm --dir admin exec tsc --noEmit",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1023.0",
    "@hono/node-server": "^1.19.12",
    "@hono/trpc-server": "^0.4.2",
    "@trpc/server": "^11.16.0",
    "bullmq": "^5.73.0",
    "cheerio": "^1.2.0",
    "commander": "^14.0.3",
    "dotenv": "^17.4.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.10",
    "ioredis": "5.8.2",
    "js-yaml": "^4.1.1",
    "json5": "^2.2.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.8",
    "slugify": "^1.6.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testcontainers/postgresql": "^11.13.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.12.2",
    "@vitest/coverage-v8": "^4.1.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.0.1",
    "msw": "^2.12.14",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "testcontainers": "^11.13.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
